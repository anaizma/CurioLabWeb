# CurioLab platform backend environment (template)
# Copy to the host secret store. Never commit real values.
# This file lists names and shapes only.

# --- Database ---
# The app connects as the restricted curiolab_app role, never the owner.
DATABASE_URL=postgres://curiolab_app:CHANGE_ME@HOST:5432/curiolab
# Optional separate read-only connection for analytics tooling (Mechanism A).
DATABASE_URL_ANALYTICS=postgres://curiolab_analytics:CHANGE_ME@HOST:5432/curiolab

# --- Sessions ---
# 32+ random bytes, base64. Used for session token hashing pepper / signing.
SESSION_SECRET=CHANGE_ME

# --- Email (Resend) ---
RESEND_API_KEY=CHANGE_ME
# Separate subdomains keep transactional and bulk reputations apart.
MAIL_TRANSACTIONAL_FROM=notify@notify.example.org
MAIL_NEWSLETTER_FROM=news@mail.example.org
RESEND_WEBHOOK_SECRET=CHANGE_ME

# --- Object storage (Cloudflare R2, private) ---
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET=curiolab-documents

# --- Billing (Stripe) ---
STRIPE_WEBHOOK_SECRET=CHANGE_ME
# No secret key is needed here for read-only status; add only if the backend
# ever initiates charges, which the current design does not.

# --- Runtime ---
NODE_ENV=production
APP_URL=https://platform.example.org
