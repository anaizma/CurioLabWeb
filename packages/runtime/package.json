{
  "name": "@curiolab/runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CurioLab platform runtime: session auth, audit writer, the authorize wrapper, the AsyncLocalStorage authorization context with the repository-write backstop, and the route manifest scaffold.",
  "main": "src/index.ts",
