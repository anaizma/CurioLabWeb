    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^20",
    "embedded-postgres": "17.10.0-beta.17",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
