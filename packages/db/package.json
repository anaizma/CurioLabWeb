{
  "name": "@curiolab/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CurioLab platform database floor: Drizzle schema, SQL guarantees, and Mechanism A roles.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@curiolab/core": "*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^20",
    "drizzle-kit": "^0.31.10",
    "embedded-postgres": "17.10.0-beta.17",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
